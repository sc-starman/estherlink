# Domain that will receive TLS cert and route to backend container
OMNIRELAY_DOMAIN=api.example.com

# Email used for Let's Encrypt registration/expiry notices
LETSENCRYPT_EMAIL=ops@example.com

# nginx-proxy max request body size (needed for MSI upload endpoint)
NGINX_CLIENT_MAX_BODY_SIZE=1024m

# pgAdmin public domain and login bootstrap credentials
PGADMIN_DOMAIN=pgadmin.example.com
PGADMIN_DEFAULT_EMAIL=admin@example.com
PGADMIN_DEFAULT_PASSWORD=change-me
PGADMIN_SERVER_MODE=False

# Public support mailbox receiving contact-form messages
SUPPORT_EMAIL=support@example.com

# SMTP settings used by backend Contact page
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USE_SSL=true
SMTP_REQUIRE_AUTH=true
SMTP_USERNAME=mailer@example.com
SMTP_PASSWORD=change-me
SMTP_FROM_EMAIL=noreply@example.com
SMTP_FROM_NAME=OmniRelay Contact

# reCAPTCHA v3 (optional, used by Contact page when enabled)
SPAM_RECAPTCHA_ENABLED=false
SPAM_RECAPTCHA_SITE_KEY=
SPAM_RECAPTCHA_SECRET_KEY=
SPAM_RECAPTCHA_VERIFY_URL=https://www.google.com/recaptcha/api/siteverify
SPAM_RECAPTCHA_EXPECTED_ACTION=contact_form
SPAM_RECAPTCHA_MINIMUM_SCORE=0.5

# Backend installer storage upload limit (MB)
INSTALLER_STORAGE_MAX_UPLOAD_MB=1024
