<Page x:Class="OmniRelay.UI.Views.Pages.LicensePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      mc:Ignorable="d"
      Title="License Management"
      Background="{DynamicResource Brush.Background}">
    <Page.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
    </Page.Resources>
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="28" MaxWidth="980">
            <StackPanel Margin="0,0,0,16">
                <TextBlock Text="License Activation" Style="{StaticResource SectionTitleTextStyle}"/>
                <TextBlock Text="Enter your license key to activate professional features and unlock enterprise security protocols." Style="{StaticResource MutedTextStyle}"/>
            </StackPanel>

            <Border Style="{StaticResource CardStyle}" Margin="0,0,0,18">
                <StackPanel>
                    <Border Padding="10" CornerRadius="8" Margin="0,0,0,10"
                            Background="{DynamicResource Brush.InputBackground}"
                            BorderBrush="{DynamicResource Brush.Border}"
                            BorderThickness="1">
                        <DockPanel LastChildFill="True">
                            <Button Content="Refresh Check"
                                    Command="{Binding RefreshServiceCompatibilityCommand}"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Margin="10,0,0,0"
                                    DockPanel.Dock="Right"/>
                            <TextBlock Text="{Binding ServiceCompatibilityMessage}"
                                       Style="{StaticResource MutedTextStyle}"
                                       VerticalAlignment="Center"/>
                        </DockPanel>
                    </Border>

                    <TextBlock Text="License Key" Style="{StaticResource FormLabelStyle}" Margin="0,0,0,6"/>
                    <DockPanel LastChildFill="False">
                        <TextBox Width="520"
                                 Text="{Binding State.LicenseKey, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource FormTextBoxStyle}"
                                 VerticalAlignment="Center"/>
                        <Button Content="Activate License"
                                Command="{Binding ActivateLicenseCommand}"
                                IsEnabled="{Binding IsServiceCompatible}"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Margin="12,0,0,0"
                                VerticalAlignment="Center"/>
                    </DockPanel>

                    <Border Margin="0,10,0,0"
                            Padding="10"
                            CornerRadius="8"
                            Visibility="{Binding TransferRequired, Converter={StaticResource BoolToVisibilityConverter}}"
                            Background="{DynamicResource Brush.InputBackground}"
                            BorderBrush="{DynamicResource Brush.Border}"
                            BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="This license is active on another device."
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource Brush.Text}"/>
                            <TextBlock Margin="0,4,0,0"
                                       Text="{Binding ActiveDeviceHint, StringFormat=Current device hint: {0}}"
                                       Style="{StaticResource MutedTextStyle}"/>
                            <TextBlock Margin="0,2,0,0"
                                       Text="{Binding TransfersRemainingInWindow, StringFormat=Transfers remaining this year: {0}}"
                                       Style="{StaticResource MutedTextStyle}"/>
                            <Button Content="Transfer To This Device"
                                    Command="{Binding TransferLicenseCommand}"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Margin="0,8,0,0"
                                    Width="220"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>

            <UniformGrid Columns="3" Margin="0,0,0,18">
                <Border Style="{StaticResource CardStyle}" Margin="0,0,12,0">
                    <StackPanel>
                        <TextBlock Text="License Status" Style="{StaticResource CardLabelStyle}"/>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{Binding LicenseStatus}" Style="{StaticResource CardValueStyle}"/>
                            <Ellipse Width="8" Height="8" Margin="8,8,0,0"
                                     Fill="{Binding LicenseActive, Converter={StaticResource BoolToStatusBrushConverter}}"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource CardStyle}" Margin="0,0,12,0">
                    <StackPanel>
                        <TextBlock Text="Expiration Date" Style="{StaticResource CardLabelStyle}"/>
                        <TextBlock Text="{Binding ExpirationDate}" Style="{StaticResource CardValueStyle}"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <TextBlock Text="Device Fingerprint" Style="{StaticResource CardLabelStyle}"/>
                        <TextBlock Text="{Binding DeviceFingerprint}" Style="{StaticResource CardValueStyle}" FontFamily="Consolas"/>
                    </StackPanel>
                </Border>
            </UniformGrid>

            <Border Style="{StaticResource HighlightBannerStyle}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="{Binding BannerTitle}" FontSize="18" FontWeight="SemiBold" Foreground="{DynamicResource Brush.Text}"/>
                        <TextBlock Text="{Binding BannerDescription}"
                                   TextWrapping="Wrap"
                                   Margin="0,6,0,0"
                                   Foreground="{DynamicResource Brush.MutedText}"/>
                    </StackPanel>
                    <Button Grid.Column="1"
                            Content="{Binding BannerActionText}"
                            IsEnabled="{Binding BannerActionEnabled}"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Margin="14,0,0,0"
                            VerticalAlignment="Center"/>
                </Grid>
            </Border>

            <TextBlock Text="{Binding Feedback}" Style="{StaticResource FeedbackTextStyle}" Margin="0,14,0,0"/>
        </StackPanel>
    </ScrollViewer>
</Page>
