<Page x:Class="EstherLink.UI.Views.Pages.GatewayManagementPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      mc:Ignorable="d"
      Title="Gateway Management"
      Background="{DynamicResource Brush.Background}">
    <Page.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
    </Page.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="28" MaxWidth="1080">
            <TextBlock Text="Gateway Management" Style="{StaticResource SectionTitleTextStyle}"/>
            <TextBlock Text="Configure tunnel/gateway parameters and manage VPS gateway lifecycle independently."
                       Style="{StaticResource MutedTextStyle}"
                       Margin="0,0,0,16"/>

            <Border Style="{StaticResource CardStyle}" Margin="0,0,0,14">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="220"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>

                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="Tunnel Host" Style="{StaticResource FormLabelStyle}"/>
                    <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding State.TunnelHost, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FormTextBoxStyle}"/>

                    <TextBlock Grid.Row="1" Text="Tunnel SSH Port" Style="{StaticResource FormLabelStyle}"/>
                    <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding State.TunnelSshPortText, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FormTextBoxStyle}"/>

                    <TextBlock Grid.Row="2" Text="Tunnel Remote Port" Style="{StaticResource FormLabelStyle}"/>
                    <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding State.TunnelRemotePortText, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FormTextBoxStyle}"/>

                    <TextBlock Grid.Row="3" Text="Tunnel User" Style="{StaticResource FormLabelStyle}"/>
                    <TextBox Grid.Row="3" Grid.Column="1" Text="{Binding State.TunnelUser, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FormTextBoxStyle}"/>

                    <TextBlock Grid.Row="4" Text="Authentication Method" Style="{StaticResource FormLabelStyle}"/>
                    <ComboBox Grid.Row="4" Grid.Column="1"
                              SelectedValue="{Binding State.TunnelAuthMethod}"
                              SelectedValuePath="Tag"
                              Style="{StaticResource FormComboBoxStyle}">
                        <ComboBoxItem Content="Host Key File" Tag="host_key"/>
                        <ComboBoxItem Content="Password" Tag="password"/>
                    </ComboBox>

                    <TextBlock Grid.Row="5"
                               Text="Host Key File"
                               Style="{StaticResource FormLabelStyle}"
                               Visibility="{Binding IsHostKeyAuthSelected, Converter={StaticResource BoolToVisibilityConverter}}"/>
                    <StackPanel Grid.Row="5"
                                Grid.Column="1"
                                Orientation="Horizontal"
                                Visibility="{Binding IsHostKeyAuthSelected, Converter={StaticResource BoolToVisibilityConverter}}">
                        <TextBox Width="520" Text="{Binding State.TunnelKeyPath, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FormTextBoxStyle}"/>
                        <Button Content="Choose File"
                                Margin="10,6,0,6"
                                Command="{Binding BrowseTunnelKeyCommand}"
                                Style="{StaticResource SecondaryButtonStyle}"/>
                    </StackPanel>

                    <TextBlock Grid.Row="6"
                               Text="Key Passphrase"
                               Style="{StaticResource FormLabelStyle}"
                               Visibility="{Binding IsHostKeyAuthSelected, Converter={StaticResource BoolToVisibilityConverter}}"/>
                    <StackPanel Grid.Row="6"
                                Grid.Column="1"
                                Orientation="Horizontal"
                                VerticalAlignment="Center"
                                Visibility="{Binding IsHostKeyAuthSelected, Converter={StaticResource BoolToVisibilityConverter}}">
                        <TextBlock Text="{Binding KeyPassphraseState}" Style="{StaticResource ValueTextStyle}" Width="130"/>
                        <Button Content="Set Passphrase"
                                Command="{Binding SetKeyPassphraseCommand}"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Margin="0,6,0,6"/>
                        <Button Content="Clear"
                                Command="{Binding ClearKeyPassphraseCommand}"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Margin="10,6,0,6"/>
                    </StackPanel>

                    <TextBlock Grid.Row="7"
                               Text="Tunnel Password"
                               Style="{StaticResource FormLabelStyle}"
                               Visibility="{Binding IsPasswordAuthSelected, Converter={StaticResource BoolToVisibilityConverter}}"/>
                    <StackPanel Grid.Row="7"
                                Grid.Column="1"
                                Orientation="Horizontal"
                                VerticalAlignment="Center"
                                Visibility="{Binding IsPasswordAuthSelected, Converter={StaticResource BoolToVisibilityConverter}}">
                        <TextBlock Text="{Binding PasswordState}" Style="{StaticResource ValueTextStyle}" Width="130"/>
                        <Button Content="Set Password"
                                Command="{Binding SetTunnelPasswordCommand}"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Margin="0,6,0,6"/>
                        <Button Content="Clear"
                                Command="{Binding ClearTunnelPasswordCommand}"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Margin="10,6,0,6"/>
                    </StackPanel>

                    <TextBlock Grid.Row="8" Text="Bootstrap SOCKS Local Port" Style="{StaticResource FormLabelStyle}"/>
                    <TextBox Grid.Row="8" Grid.Column="1" Text="{Binding State.BootstrapSocksLocalPortText, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FormTextBoxStyle}"/>

                    <TextBlock Grid.Row="9" Text="Bootstrap SOCKS Remote Port" Style="{StaticResource FormLabelStyle}"/>
                    <TextBox Grid.Row="9" Grid.Column="1" Text="{Binding State.BootstrapSocksRemotePortText, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FormTextBoxStyle}"/>

                    <TextBlock Grid.Row="10" Text="Gateway Public/Panel Ports" Style="{StaticResource FormLabelStyle}"/>
                    <StackPanel Grid.Row="10" Grid.Column="1" Orientation="Horizontal">
                        <TextBox Width="180" Margin="0,6,8,6" Text="{Binding State.GatewayPublicPortText, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FormTextBoxStyle}"/>
                        <TextBox Width="180" Margin="0,6,0,6" Text="{Binding State.GatewayPanelPortText, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FormTextBoxStyle}"/>
                    </StackPanel>

                                        <WrapPanel Grid.Row="11" Grid.Column="1">
                        <Button Content="Apply Gateway Config" Command="{Binding ApplyGatewayConfigCommand}" Style="{StaticResource PrimaryButtonStyle}" Margin="0,0,8,0"/>
                        <Button Content="Test Tunnel" Command="{Binding TestTunnelConnectionCommand}" Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,8,0"/>
                        </WrapPanel>
                </Grid>
            </Border>

            <Border Style="{StaticResource CardStyle}" Margin="0,0,0,14">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="220"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="Gateway DNS Mode" Style="{StaticResource FormLabelStyle}"/>
                    <ComboBox Grid.Row="0" Grid.Column="1"
                              SelectedValue="{Binding State.GatewayDnsMode}"
                              SelectedValuePath="Tag"
                              Style="{StaticResource FormComboBoxStyle}">
                        <ComboBoxItem Content="Hybrid (UDP + DoH)" Tag="hybrid"/>
                        <ComboBoxItem Content="DoH Only" Tag="doh"/>
                        <ComboBoxItem Content="UDP DNS Only" Tag="udp"/>
                    </ComboBox>

                    <TextBlock Grid.Row="1" Text="DoH Endpoints (CSV)" Style="{StaticResource FormLabelStyle}"/>
                    <TextBox Grid.Row="1" Grid.Column="1"
                             Text="{Binding State.GatewayDohEndpointsText, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource FormTextBoxStyle}"/>

                    <TextBlock Grid.Row="2" Text="Block Non-DNS UDP" Style="{StaticResource FormLabelStyle}"/>
                    <CheckBox Grid.Row="2" Grid.Column="1"
                              VerticalAlignment="Center"
                              IsChecked="{Binding State.GatewayDnsUdpOnly}"
                              Content="Allow only UDP/53 and block other UDP"
                              Margin="0,6,0,6"/>

                                                  <WrapPanel  Grid.Row="3" Grid.Column="1">
                                                <Button Content="Apply DNS Config" Command="{Binding ApplyGatewayDnsCommand}" Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,8,0"/>
                        <Button Content="Check DNS Path" Command="{Binding CheckGatewayDnsCommand}" Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,8,0"/>
                        <Button Content="Repair DNS" Command="{Binding RepairGatewayDnsCommand}" Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,8,0"/>

</WrapPanel>
                </Grid>

            </Border>

            <Border Style="{StaticResource CardStyle}" Margin="0,0,0,14">
                <StackPanel>
                    <TextBlock Text="Gateway Operations" FontWeight="SemiBold" Margin="0,0,0,10"/>
                    <WrapPanel Margin="0,0,0,10">
                        <Button Content="Bootstrap Check" Command="{Binding GatewayBootstrapCheckCommand}" Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,8,0"/>
                        <Button Content="Install Gateway" Command="{Binding InstallGatewayCommand}" Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,8,0"/>
                        <Button Content="Start" Command="{Binding StartGatewayCommand}" Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,8,0"/>
                        <Button Content="Stop" Command="{Binding StopGatewayCommand}" Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,8,0"/>
                        <Button Content="Uninstall" Command="{Binding UninstallGatewayCommand}" Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,8,0"/>
                        <Button Content="Health Check" Command="{Binding HealthCheckGatewayCommand}" Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,8,0"/>
                        <Button Content="Refresh" Command="{Binding RefreshCommand}" Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,8,0"/>
                        <Button Content="Clear Session Sudo" Command="{Binding ClearCachedSudoPasswordCommand}" Style="{StaticResource SecondaryButtonStyle}"/>
                    </WrapPanel>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="220"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Text="Gateway Service State" Style="{StaticResource FormLabelStyle}"/>
                        <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding GatewayServiceState}" TextWrapping="Wrap" Style="{StaticResource ValueTextStyle}"/>

                        <TextBlock Grid.Row="1" Text="Bootstrap Check" Style="{StaticResource FormLabelStyle}"/>
                        <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding GatewayBootstrapState}" Style="{StaticResource ValueTextStyle}"/>

                        <TextBlock Grid.Row="2" Text="Health" Style="{StaticResource FormLabelStyle}"/>
                        <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding GatewayHealthSummary}" TextWrapping="Wrap" Style="{StaticResource ValueTextStyle}"/>

                        <TextBlock Grid.Row="3" Text="Sudo Password Cache" Style="{StaticResource FormLabelStyle}"/>
                        <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding HasCachedSudoPassword}" Style="{StaticResource ValueTextStyle}"/>

                        <TextBlock Grid.Row="4" Text="DNS Summary" Style="{StaticResource FormLabelStyle}"/>
                        <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding GatewayDnsSummary}" TextWrapping="Wrap" Style="{StaticResource ValueTextStyle}"/>
                    </Grid>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource CardStyle}" Margin="0,0,0,8">
                <StackPanel>
                    <TextBlock Text="Gateway Operation Log" FontWeight="SemiBold" Margin="0,0,0,10"/>
                    <TextBox Text="{Binding OperationLog}"
                             IsReadOnly="True"
                             Height="220"
                             VerticalScrollBarVisibility="Auto"
                             HorizontalScrollBarVisibility="Auto"
                             TextWrapping="Wrap"
                             Style="{StaticResource MultilineTextBoxStyle}"/>
                </StackPanel>
            </Border>

            <TextBlock Text="{Binding Feedback}" Style="{StaticResource FeedbackTextStyle}" Margin="0,10,0,0"/>
        </StackPanel>
    </ScrollViewer>
</Page>
