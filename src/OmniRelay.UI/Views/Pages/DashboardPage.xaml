<Page x:Class="OmniRelay.UI.Views.Pages.DashboardPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      mc:Ignorable="d"
      Title="Dashboard"
      Background="{DynamicResource Brush.Background}">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="28">
            <TextBlock Text="Operational Overview" Style="{StaticResource SectionTitleTextStyle}"/>
            <TextBlock Text="Live gateway health and quick control actions." Style="{StaticResource MutedTextStyle}" Margin="0,0,0,16"/>

            <UniformGrid Columns="2" Margin="0,0,0,16">
                <Border Style="{StaticResource CardStyle}" Margin="0,0,10,0">
                    <StackPanel>
                        <TextBlock Text="Service" Style="{StaticResource CardLabelStyle}"/>
                        <TextBlock Text="{Binding ServiceState}" Style="{StaticResource CardValueStyle}"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource CardStyle}" Margin="0,0,10,0">
                    <StackPanel>
                        <TextBlock Text="Proxy" Style="{StaticResource CardLabelStyle}"/>
                        <TextBlock Text="{Binding ProxyState}" Style="{StaticResource CardValueStyle}"/>
                    </StackPanel>
                </Border>
            </UniformGrid>
            <UniformGrid Columns="2" Margin="0,0,0,16">
                <Border Style="{StaticResource CardStyle}" Margin="0,0,10,0">
                    <StackPanel>
                        <TextBlock Text="License" Style="{StaticResource CardLabelStyle}"/>
                        <TextBlock Text="{Binding LicenseState}" Style="{StaticResource CardValueStyle}"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource CardStyle}" Margin="0,0,10,0">
                    <StackPanel>
                        <TextBlock Text="Tunnel" Style="{StaticResource CardLabelStyle}"/>
                        <TextBlock Text="{Binding TunnelState}" Style="{StaticResource CardValueStyle}"/>
                    </StackPanel>
                </Border>
            </UniformGrid>

            <WrapPanel Margin="0,0,0,12">
                <Button Content="Refresh Status" Command="{Binding RefreshCommand}" Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,10,0"/>
                <Button Content="Verify License" Command="{Binding VerifyLicenseCommand}" Style="{StaticResource PrimaryButtonStyle}" Margin="0,0,10,0"/>
                <Button Content="Start Proxy" Command="{Binding StartProxyCommand}" Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,10,0"/>
                <Button Content="Stop Proxy" Command="{Binding StopProxyCommand}" Style="{StaticResource SecondaryButtonStyle}"/>
            </WrapPanel>

            <TextBlock Text="{Binding Feedback}" Style="{StaticResource FeedbackTextStyle}"/>
        </StackPanel>
    </ScrollViewer>
</Page>
