<Window x:Class="OmniRelay.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="OmniRelay"
        Icon="Assets/app.ico"
        WindowStyle="None"
        ResizeMode="CanMinimize"
        Width="900"
        Height="700"
        MinWidth="900"
        MinHeight="700">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="40"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="{DynamicResource Brush.HeaderBackground}"
                BorderBrush="{DynamicResource Brush.Border}"
                BorderThickness="0,0,0,1"
                MouseLeftButtonDown="TitleBar_OnMouseLeftButtonDown">
            <Grid Margin="12,0,8,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <Image Source="pack://application:,,,/Assets/logo.png"
                           Width="18"
                           Height="18"
                           Margin="0,0,8,0"/>
                    <TextBlock Text="OmniRelay"
                               FontWeight="SemiBold"
                               FontSize="13"/>
                </StackPanel>

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <Button Width="30"
                            Height="24"
                            MinHeight="24"
                            Margin="0,0,6,0"
                            Padding="0"
                            ToolTip="Minimize"
                            Click="MinimizeButton_OnClick"
                            Style="{StaticResource SecondaryButtonStyle}">
                        <TextBlock Text="&#xE921;"
                                   FontFamily="Segoe MDL2 Assets"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Button>
                    <Button Width="30"
                            Height="24"
                            MinHeight="24"
                            Padding="0"
                            ToolTip="Close"
                            Click="CloseButton_OnClick"
                            Style="{StaticResource SecondaryButtonStyle}">
                        <TextBlock Text="&#xE8BB;"
                                   FontFamily="Segoe MDL2 Assets"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

        <Border Grid.Column="0"
                Background="{DynamicResource Brush.SidebarBackground}"
                BorderBrush="{DynamicResource Brush.Border}"
                BorderThickness="0,0,1,0">
            <DockPanel>
                <Border DockPanel.Dock="Bottom"
                        Margin="20,0,20,20"
                        Padding="10,8"
                        CornerRadius="8"
                        BorderBrush="{DynamicResource Brush.Border}"
                        BorderThickness="1">
                    <TextBlock FontSize="11"
                               Foreground="{DynamicResource Brush.MutedText}"
                               TextAlignment="Center">
                        <Run Text="© 2026 OmniRelay"/>
                        <LineBreak/>
                        <Hyperlink NavigateUri="https://omnirelay.net"
                                   RequestNavigate="FooterLink_RequestNavigate">OmniRelay.net</Hyperlink>
                        <LineBreak/>
                        <Run Text="{Binding SidebarVersionText}"/>
                    </TextBlock>
                </Border>

                <!-- <Border DockPanel.Dock="Bottom"
                        Margin="20"
                        Padding="14"
                        Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <TextBlock Text="Current Plan" Style="{StaticResource CardLabelStyle}"/>
                        <TextBlock Text="Professional" Margin="0,4,0,10" FontWeight="Bold"/>
                        <ProgressBar Height="8" Value="85" Maximum="100" Foreground="{DynamicResource Brush.Primary}"/>
                    </StackPanel>
                </Border> -->

                <StackPanel Margin="20,24,20,20">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,24">
                        <Border Width="44"
                                Height="44"
                                CornerRadius="22"
                                Background="{DynamicResource Brush.NavActiveBackground}"
                                BorderBrush="{DynamicResource Brush.Primary}"
                                BorderThickness="1"
                                Padding="6">
                            <Image Source="pack://application:,,,/Assets/logo.png" Stretch="Uniform"/>
                        </Border>
                        <StackPanel Margin="12,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="OmniRelay" Style="{StaticResource SidebarTitleStyle}"/>
                            <TextBlock Text="Own Connectivity" Style="{StaticResource SidebarSubTitleStyle}"/>
                        </StackPanel>
                    </StackPanel>

                    <ItemsControl ItemsSource="{Binding NavigationItems}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button Style="{StaticResource SidebarNavButtonStyle}"
                                        Margin="0,0,0,4"
                                        IsEnabled="{Binding IsEnabled}"
                                        Command="{Binding DataContext.NavigateCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                        CommandParameter="{Binding Item.Route}">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding Item.IconGlyph}" FontFamily="Segoe MDL2 Assets" FontSize="16" Width="24" VerticalAlignment="Center"/>
                                        <TextBlock Text="{Binding Item.Title}" VerticalAlignment="Center" FontSize="13"/>
                                    </StackPanel>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </DockPanel>
        </Border>

        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="64"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="36"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Background="{DynamicResource Brush.HeaderBackground}"
                    BorderBrush="{DynamicResource Brush.Border}"
                    BorderThickness="0,0,0,1">
                <Grid Margin="24,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="{Binding PageIconGlyph}"
                                   FontFamily="Segoe MDL2 Assets"
                                   Foreground="{DynamicResource Brush.Primary}"
                                   FontSize="18"
                                   VerticalAlignment="Center"
                                   Margin="0,2,8,0"/>
                        <TextBlock Text="{Binding PageTitle}" FontSize="20" FontWeight="Bold"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <Button Style="{StaticResource SecondaryButtonStyle}" Padding="10,6" Margin="0,0,10,0" Command="{Binding ToggleThemeCommand}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE706;"
                                           FontFamily="Segoe MDL2 Assets"
                                           VerticalAlignment="Center"
                                           Margin="0,2,6,0"/>
                                <TextBlock Text="{Binding ThemeLabel}"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <Frame x:Name="ContentFrame"
                   Grid.Row="1"
                   NavigationUIVisibility="Hidden"
                   Background="Transparent"/>

            <Border Grid.Row="2"
                    Background="{DynamicResource Brush.FooterBackground}"
                    BorderBrush="{DynamicResource Brush.Border}"
                    BorderThickness="0,1,0,0"
                    Padding="14,6">
                <TextBlock Text="{Binding StatusSummary}" FontSize="12" Foreground="{DynamicResource Brush.MutedText}" TextTrimming="CharacterEllipsis"/>
            </Border>
        </Grid>
        </Grid>
    </Grid>
</Window>
