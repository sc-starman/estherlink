<Page x:Class="OmniRelay.UI.Views.Pages.SettingsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      mc:Ignorable="d"
      Title="Settings"
      Background="{DynamicResource Brush.Background}">
    <StackPanel Margin="28" MaxWidth="760">
        <TextBlock Text="Settings" Style="{StaticResource SectionTitleTextStyle}"/>
        <TextBlock Text="Theme and UI preference controls." Style="{StaticResource MutedTextStyle}" Margin="0,0,0,16"/>

        <Border Style="{StaticResource CardStyle}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="220"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="Dark Theme" Style="{StaticResource FormLabelStyle}"/>
                <CheckBox Grid.Row="0" Grid.Column="1" IsChecked="{Binding DarkThemeEnabled}" VerticalAlignment="Center" Foreground="{DynamicResource Brush.Text}"/>

                <TextBlock Grid.Row="1" Text="Refresh Interval (sec)" Style="{StaticResource FormLabelStyle}"/>
                <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding RefreshIntervalSeconds}" Style="{StaticResource FormTextBoxStyle}"/>

                <TextBlock Grid.Row="2" Text="Compact Mode" Style="{StaticResource FormLabelStyle}"/>
                <CheckBox Grid.Row="2" Grid.Column="1" IsChecked="{Binding CompactMode}" VerticalAlignment="Center" Foreground="{DynamicResource Brush.Text}"/>
            </Grid>
        </Border>

        <WrapPanel Margin="0,14,0,0">
            <Button Content="Save Settings" Command="{Binding SaveCommand}" Style="{StaticResource PrimaryButtonStyle}" Margin="0,0,10,0"/>
            <Button Content="Reset Defaults" Command="{Binding ResetDefaultsCommand}" Style="{StaticResource SecondaryButtonStyle}"/>
        </WrapPanel>

        <TextBlock Text="{Binding Feedback}" Style="{StaticResource FeedbackTextStyle}" Margin="0,10,0,0"/>
    </StackPanel>
</Page>
