@page "/contact"
@model EstherLink.Backend.Pages.ContactModel
@{
    ViewData["Title"] = "Contact";
}

<section class="max-w-3xl mx-auto px-4 py-16">
    <h1 class="text-4xl font-bold mb-3">Contact Us</h1>
    <p class="text-slate-300 mb-8">Tell us what you need and we will get back to you by email.</p>

    @if (!string.IsNullOrWhiteSpace(Model.SuccessMessage))
    {
        <div class="mb-6 p-4 rounded-md border border-green-600/50 bg-green-500/10 text-green-200">
            @Model.SuccessMessage
        </div>
    }
    @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
    {
        <div class="mb-6 p-4 rounded-md border border-red-600/50 bg-red-500/10 text-red-200">
            @Model.ErrorMessage
        </div>
    }

    <form id="contactForm" method="post" class="space-y-5 p-6 rounded-xl border border-slate-800 bg-slate-900">
        @Html.AntiForgeryToken()

        <div class="absolute -left-[9999px] top-auto w-px h-px overflow-hidden" aria-hidden="true">
            <label asp-for="Input.Website"></label>
            <input asp-for="Input.Website" tabindex="-1" autocomplete="off" />
        </div>

        <input asp-for="Input.RecaptchaToken" type="hidden" id="recaptchaToken" />

        <div>
            <label asp-for="Input.Name" class="block text-sm mb-2"></label>
            <input asp-for="Input.Name" class="w-full px-3 py-2 rounded-md border border-slate-700 bg-slate-950 focus:outline-none focus:ring-2 focus:ring-cyan-500" />
            <span asp-validation-for="Input.Name" class="text-red-300 text-sm"></span>
        </div>

        <div>
            <label asp-for="Input.Email" class="block text-sm mb-2"></label>
            <input asp-for="Input.Email" class="w-full px-3 py-2 rounded-md border border-slate-700 bg-slate-950 focus:outline-none focus:ring-2 focus:ring-cyan-500" />
            <span asp-validation-for="Input.Email" class="text-red-300 text-sm"></span>
        </div>

        <div>
            <label asp-for="Input.Subject" class="block text-sm mb-2"></label>
            <input asp-for="Input.Subject" class="w-full px-3 py-2 rounded-md border border-slate-700 bg-slate-950 focus:outline-none focus:ring-2 focus:ring-cyan-500" />
            <span asp-validation-for="Input.Subject" class="text-red-300 text-sm"></span>
        </div>

        <div>
            <label asp-for="Input.Message" class="block text-sm mb-2"></label>
            <textarea asp-for="Input.Message" rows="8" class="w-full px-3 py-2 rounded-md border border-slate-700 bg-slate-950 focus:outline-none focus:ring-2 focus:ring-cyan-500"></textarea>
            <span asp-validation-for="Input.Message" class="text-red-300 text-sm"></span>
        </div>

        <button type="submit" class="px-6 py-3 rounded-md bg-cyan-500 text-slate-900 font-semibold hover:bg-cyan-400">Send Message</button>
    </form>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    @if (Model.RecaptchaEnabled && !string.IsNullOrWhiteSpace(Model.RecaptchaSiteKey))
    {
        <script src="https://www.google.com/recaptcha/api.js?render=@Model.RecaptchaSiteKey"></script>
        <script>
            (function () {
                const form = document.getElementById("contactForm");
                if (!form || !window.grecaptcha) return;

                form.addEventListener("submit", function (event) {
                    if (form.dataset.recaptchaReady === "true") return;
                    event.preventDefault();

                    grecaptcha.ready(function () {
                        grecaptcha.execute("@Model.RecaptchaSiteKey", { action: "contact_form" })
                            .then(function (token) {
                                document.getElementById("recaptchaToken").value = token || "";
                                form.dataset.recaptchaReady = "true";
                                form.submit();
                            });
                    });
                });
            })();
        </script>
    }
}
