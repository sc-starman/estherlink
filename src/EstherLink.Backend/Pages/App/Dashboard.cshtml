@page "/app/dashboard"
@model EstherLink.Backend.Pages.App.DashboardModel
@{
    ViewData["Title"] = "Dashboard";
    ViewData["DocumentationUrl"] = Model.DocumentationUrl;
}

<div class="max-w-7xl mx-auto px-4 py-10 space-y-8">
    <div>
        <h1 class="text-3xl font-bold">Dashboard</h1>
        <p class="text-slate-400 mt-1">Welcome back, @Model.Email.</p>
    </div>

    <div class="grid md:grid-cols-4 gap-4">
        <div class="rounded-xl border border-slate-800 bg-slate-900 p-4"><p class="text-xs text-slate-400">Licenses</p><p class="text-2xl font-bold">@Model.LicenseCount</p></div>
        <div class="rounded-xl border border-slate-800 bg-slate-900 p-4"><p class="text-xs text-slate-400">Trial</p><p class="text-2xl font-bold">@(Model.HasTrial ? "Issued" : "Not used")</p></div>
        <div class="rounded-xl border border-slate-800 bg-slate-900 p-4"><p class="text-xs text-slate-400">Paid License</p><p class="text-2xl font-bold">@(Model.HasPaid ? "Active" : "None")</p></div>
        <div class="rounded-xl border border-slate-800 bg-slate-900 p-4"><p class="text-xs text-slate-400">Latest Build</p><p class="text-2xl font-bold">@Model.LatestVersion</p></div>
    </div>

    <div class="rounded-xl border border-slate-800 bg-slate-900 p-6 space-y-4">
        <h2 class="text-xl font-semibold">Quick Actions</h2>
        <div class="flex flex-wrap gap-3">
            <button type="button" data-action="start-trial" class="px-4 py-2 rounded bg-cyan-500 text-slate-900 font-semibold hover:bg-cyan-400">Start 2-Day Trial</button>
            <a href="/app/billing" class="px-4 py-2 rounded bg-slate-800 hover:bg-slate-700">Buy One-Time License</a>
            <a href="/app/downloads" class="px-4 py-2 rounded bg-slate-800 hover:bg-slate-700">Download Application</a>
        </div>
        <div id="trial-result" class="text-sm text-slate-300"></div>
    </div>
</div>