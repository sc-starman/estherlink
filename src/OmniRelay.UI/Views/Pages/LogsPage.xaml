<Page x:Class="OmniRelay.UI.Views.Pages.LogsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      mc:Ignorable="d"
      Title="Logs"
      Background="{DynamicResource Brush.Background}">
    <Grid Margin="28">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,12">
            <TextBlock Text="Service log stream with filter and refresh controls." Style="{StaticResource MutedTextStyle}"/>
        </StackPanel>

        <WrapPanel Grid.Row="1" Margin="0,0,0,10">
            <TextBox Width="340" Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FormTextBoxStyle}" />
            <CheckBox Content="Tail Mode"
                      IsChecked="{Binding TailMode}"
                      Margin="10,0,0,0"
                      VerticalAlignment="Center"
                      Foreground="{DynamicResource Brush.Text}"/>
            <Button Content="Refresh" Command="{Binding RefreshCommand}" Style="{StaticResource SecondaryButtonStyle}" Margin="10,0,0,0"/>
            <Button Content="Clear Filter" Command="{Binding ClearFilterCommand}" Style="{StaticResource SecondaryButtonStyle}" Margin="10,0,0,0"/>
            <Button Content="Copy Selected" Command="{Binding CopySelectedCommand}" Style="{StaticResource SecondaryButtonStyle}" Margin="10,0,0,0"/>
        </WrapPanel>

        <Border Grid.Row="2" Style="{StaticResource CardStyle}" Padding="0">
            <ListBox ItemsSource="{Binding LogLines}"
                     SelectedItem="{Binding SelectedLine}"
                     FontFamily="Consolas"
                     BorderThickness="0"
                     Background="Transparent"/>
        </Border>

        <TextBlock Grid.Row="3" Text="{Binding Feedback}" Style="{StaticResource FeedbackTextStyle}" Margin="0,10,0,0"/>
    </Grid>
</Page>
