<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
     xmlns:ui="http://wixtoolset.org/schemas/v4/wxs/ui">
  <Package
    Name="OmniRelay"
    Manufacturer="OmniRelay"
    Version="1.34.11"
    Language="1033"
    UpgradeCode="{95EE2733-FDA4-4B0A-91CA-43D42B3E91E7}"
    Scope="perMachine">

    <SummaryInformation Description="OmniRelay Windows Desktop + Service Installer" Manufacturer="OmniRelay" />
    <MajorUpgrade DowngradeErrorMessage="A newer version of OmniRelay is already installed." />
    <MediaTemplate EmbedCab="yes" />

    <Icon Id="OmniRelayIcon" SourceFile="..\EstherLink.UI\Assets\app.ico" />
    <Property Id="ARPPRODUCTICON" Value="OmniRelayIcon" />
    <Property Id="WIXUI_INSTALLDIR" Value="INSTALLFOLDER" />
    <ui:WixUI Id="WixUI_InstallDir" />

    <StandardDirectory Id="ProgramFiles64Folder">
      <Directory Id="INSTALLFOLDER" Name="OmniRelay">
        <Directory Id="UIDIR" Name="UI" />
        <Directory Id="SERVICEDIR" Name="Service" />
      </Directory>
    </StandardDirectory>

    <StandardDirectory Id="ProgramMenuFolder">
      <Directory Id="ProgramMenuOmniRelay" Name="OmniRelay" />
    </StandardDirectory>

    <DirectoryRef Id="ProgramMenuOmniRelay">
      <Component Id="StartMenuComponent" Guid="{B85C8A17-DF52-4477-A505-6D6134AB0B34}">
        <Shortcut
          Id="OmniRelayShortcut"
          Name="OmniRelay"
          Description="Launch OmniRelay"
          Target="[UIDIR]EstherLink.UI.exe"
          WorkingDirectory="UIDIR" />
        <RemoveFolder Id="RemoveProgramMenuOmniRelay" On="uninstall" />
        <RegistryValue Root="HKCU" Key="Software\OmniRelay" Name="StartMenuShortcut" Type="integer" Value="1" KeyPath="yes" />
      </Component>
    </DirectoryRef>

    <DirectoryRef Id="SERVICEDIR">
      <Component Id="ServiceExeComponent" Guid="{EA85C310-AF5A-4AC2-B161-BFCE4F450E8E}">
        <File Id="ServiceExeFile" Source="$(var.PayloadDir)\service\EstherLink.Service.exe" KeyPath="yes" />
        <ServiceInstall
          Id="OmniRelayServiceInstaller"
          Name="EstherLink.Service"
          DisplayName="OmniRelay Service"
          Description="OmniRelay policy egress router background service."
          Type="ownProcess"
          Start="auto"
          ErrorControl="normal"
          Vital="yes"
          Account="LocalSystem" />
        <ServiceControl
          Id="OmniRelayServiceControl"
          Name="EstherLink.Service"
          Start="install"
          Stop="both"
          Remove="uninstall"
          Wait="yes" />
      </Component>
    </DirectoryRef>

    <ComponentGroup Id="UiFiles" Directory="UIDIR">
      <Files Include="$(var.PayloadDir)\ui\**" />
    </ComponentGroup>

    <ComponentGroup Id="ServiceFiles" Directory="SERVICEDIR">
      <Files Include="$(var.PayloadDir)\service\*.dll;$(var.PayloadDir)\service\*.json" />
    </ComponentGroup>

    <ComponentGroup Id="ShellAndServiceComponents">
      <ComponentRef Id="StartMenuComponent" />
      <ComponentRef Id="ServiceExeComponent" />
    </ComponentGroup>

    <Feature Id="MainFeature" Title="OmniRelay" Level="1">
      <ComponentGroupRef Id="UiFiles" />
      <ComponentGroupRef Id="ServiceFiles" />
      <ComponentGroupRef Id="ShellAndServiceComponents" />
    </Feature>
  </Package>
</Wix>
