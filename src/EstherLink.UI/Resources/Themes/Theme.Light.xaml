<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Color x:Key="Color.Primary">#0DCCF2</Color>
    <Color x:Key="Color.Background">#F5F8F8</Color>
    <Color x:Key="Color.SidebarBackground">#F8FBFB</Color>
    <Color x:Key="Color.HeaderBackground">#FDFEFE</Color>
    <Color x:Key="Color.Surface">#FFFFFF</Color>
    <Color x:Key="Color.FooterBackground">#EEF4F6</Color>
    <Color x:Key="Color.Border">#D7E4E8</Color>
    <Color x:Key="Color.Text">#0F1E22</Color>
    <Color x:Key="Color.MutedText">#5F727A</Color>
    <Color x:Key="Color.NavHover">#EAF3F6</Color>
    <Color x:Key="Color.NavActiveBackground">#D8F7FD</Color>
    <Color x:Key="Color.InputBackground">#F7FBFC</Color>

    <SolidColorBrush x:Key="Brush.Primary" Color="{StaticResource Color.Primary}"/>
    <SolidColorBrush x:Key="Brush.Background" Color="{StaticResource Color.Background}"/>
    <SolidColorBrush x:Key="Brush.SidebarBackground" Color="{StaticResource Color.SidebarBackground}"/>
    <SolidColorBrush x:Key="Brush.HeaderBackground" Color="{StaticResource Color.HeaderBackground}"/>
    <SolidColorBrush x:Key="Brush.Surface" Color="{StaticResource Color.Surface}"/>
    <SolidColorBrush x:Key="Brush.FooterBackground" Color="{StaticResource Color.FooterBackground}"/>
    <SolidColorBrush x:Key="Brush.Border" Color="{StaticResource Color.Border}"/>
    <SolidColorBrush x:Key="Brush.Text" Color="{StaticResource Color.Text}"/>
    <SolidColorBrush x:Key="Brush.MutedText" Color="{StaticResource Color.MutedText}"/>
    <SolidColorBrush x:Key="Brush.NavHover" Color="{StaticResource Color.NavHover}"/>
    <SolidColorBrush x:Key="Brush.NavActiveBackground" Color="{StaticResource Color.NavActiveBackground}"/>
    <SolidColorBrush x:Key="Brush.InputBackground" Color="{StaticResource Color.InputBackground}"/>

    <SolidColorBrush x:Key="Brush.Success" Color="#10B981"/>
    <SolidColorBrush x:Key="Brush.Warning" Color="#F59E0B"/>
    <SolidColorBrush x:Key="Brush.Danger" Color="#EF4444"/>
</ResourceDictionary>