<Window x:Class="EstherLink.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="EstherLink Control"
        Height="820"
        Width="1100"
        MinHeight="720"
        MinWidth="980">
    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Grid Grid.Row="0" Grid.ColumnSpan="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Image Width="40"
                   Height="40"
                   Margin="0,0,10,0"
                   VerticalAlignment="Center"
                   Source="pack://application:,,,/Assets/logo.png"
                   Stretch="Uniform"/>
            <TextBlock Grid.Column="1"
                       VerticalAlignment="Center"
                       FontSize="22"
                       FontWeight="SemiBold"
                       Text="EstherLink MVP Control Panel"/>
        </Grid>
        <TextBlock Grid.Row="1" Grid.ColumnSpan="4" Margin="0,6,0,14" Foreground="#555" Text="Windows service + CONNECT proxy with adapter-bound egress (IC1/IC2)."/>

        <TextBlock Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" Text="VPS Host/IP"/>
        <TextBox Grid.Row="2" Grid.Column="1" x:Name="VpsHostTextBox" Margin="8,4,12,4" Text="vps.example.com"/>

        <TextBlock Grid.Row="2" Grid.Column="2" VerticalAlignment="Center" Text="VPS Port"/>
        <TextBox Grid.Row="2" Grid.Column="3" x:Name="VpsPortTextBox" Margin="8,4,0,4" Text="443"/>

        <TextBlock Grid.Row="3" Grid.Column="0" VerticalAlignment="Center" Text="Proxy Listen Port"/>
        <TextBox Grid.Row="3" Grid.Column="1" x:Name="ProxyPortTextBox" Margin="8,4,12,4" Text="19080"/>

        <TextBlock Grid.Row="4" Grid.Column="0" VerticalAlignment="Center" Text="VPS Network (IC1)"/>
        <ComboBox Grid.Row="4" Grid.Column="1" x:Name="VpsNetworkComboBox" Margin="8,4,12,4" DisplayMemberPath="Display"/>

        <TextBlock Grid.Row="4" Grid.Column="2" VerticalAlignment="Center" Text="Outgoing Network (IC2)"/>
        <ComboBox Grid.Row="4" Grid.Column="3" x:Name="OutgoingNetworkComboBox" Margin="8,4,0,4" DisplayMemberPath="Display"/>

        <Grid Grid.Row="5" Grid.ColumnSpan="4" Margin="0,12,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Grid.Column="0" FontWeight="SemiBold" Text="Service / License"/>
            <TextBlock Grid.Row="0" Grid.Column="1" FontWeight="SemiBold" Margin="12,0,0,0" Text="Whitelist (CIDR/IP per line, # comments allowed)"/>

            <TextBlock Grid.Row="1" Grid.Column="0" Margin="0,8,0,0" Text="License Endpoint"/>
            <TextBox Grid.Row="1" Grid.Column="0" x:Name="LicenseEndpointTextBox" Margin="130,8,12,0" Text="https://license.vendor.example/validate"/>

            <TextBlock Grid.Row="2" Grid.Column="0" Margin="0,8,0,0" Text="License Key"/>
            <TextBox Grid.Row="2" Grid.Column="0" x:Name="LicenseKeyTextBox" Margin="130,8,12,0"/>

            <TextBlock Grid.Row="3" Grid.Column="0" Margin="0,8,0,0" Text="Service EXE Path"/>
            <TextBox Grid.Row="3" Grid.Column="0" x:Name="ServiceExePathTextBox" Margin="130,8,12,0"/>

            <TextBox Grid.Row="1" Grid.Column="1" Grid.RowSpan="5" x:Name="WhitelistTextBox" Margin="12,8,0,0" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" MinHeight="220" FontFamily="Consolas"/>
        </Grid>

        <StackPanel Grid.Row="6" Grid.ColumnSpan="4" Margin="0,14,0,0">
            <WrapPanel>
                <Button x:Name="VerifyLicenseButton" Width="140" Margin="0,0,8,0" Content="Verify License" Click="VerifyLicenseButton_Click"/>
                <Button x:Name="UpdateWhitelistButton" Width="140" Margin="0,0,8,0" Content="Update Whitelist" Click="UpdateWhitelistButton_Click"/>
                <Button x:Name="InstallStartServiceButton" Width="180" Margin="0,0,8,0" Content="Install/Start Service" Click="InstallStartServiceButton_Click"/>
                <Button x:Name="StopServiceButton" Width="120" Margin="0,0,8,0" Content="Stop Service" Click="StopServiceButton_Click"/>
                <Button x:Name="RefreshStatusButton" Width="120" Content="Refresh Status" Click="RefreshStatusButton_Click"/>
            </WrapPanel>
            <Border Margin="0,10,0,0" Padding="10" BorderBrush="#DDD" BorderThickness="1" CornerRadius="4">
                <TextBlock x:Name="StatusTextBlock" TextWrapping="Wrap" FontFamily="Consolas"/>
            </Border>
        </StackPanel>
    </Grid>
</Window>
