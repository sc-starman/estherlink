@page "/dashboard/billing"
@model EstherLink.Backend.Pages.App.BillingModel
@{
    ViewData["Title"] = "Billing";
    ViewData["DashboardNav"] = "billing";
}

<div class="max-w-7xl mx-auto px-4 py-10 grid md:grid-cols-[240px_1fr] gap-6">
    <partial name="_DashboardSidebar" view-data="ViewData" />

    <section class="space-y-8">
        <div>
            <h1 class="text-3xl font-bold mb-2">Billing</h1>
            <p class="text-slate-400">Track payment attempts and license issuance status.</p>
        </div>

        <section class="rounded-xl border border-cyan-600/40 bg-cyan-500/10 p-6">
            <h2 class="text-2xl font-bold">One-Time License</h2>
            <p class="text-4xl font-bold mt-2">$@Model.PriceUsd.ToString("0.00")</p>
            <p class="text-slate-300 mt-2">Perpetual usage + 1 year software updates.</p>
            <button type="button" data-action="create-intent" class="mt-4 px-5 py-2 rounded bg-cyan-500 text-slate-900 font-semibold hover:bg-cyan-400">
                Create Payment Intent
            </button>
            <div id="checkout-result" class="mt-4 text-sm text-slate-100"></div>
        </section>

        <section>
            <h2 class="text-xl font-semibold mb-3">Payment Attempts</h2>
            @if (Model.Attempts.Count == 0)
            {
                <div class="rounded-xl border border-slate-800 bg-slate-900 p-4 text-slate-300">No payment attempts yet.</div>
            }
            else
            {
                <div class="overflow-x-auto rounded-xl border border-slate-800 bg-slate-900">
                    <table class="min-w-full text-sm">
                        <thead class="bg-slate-950/70 text-slate-300">
                            <tr>
                                <th class="text-left px-4 py-3">Attempt ID</th>
                                <th class="text-left px-4 py-3">Order ID</th>
                                <th class="text-left px-4 py-3">Amount</th>
                                <th class="text-left px-4 py-3">Currency</th>
                                <th class="text-left px-4 py-3">State</th>
                                <th class="text-left px-4 py-3">Created At</th>
                                <th class="text-left px-4 py-3">Updated At</th>
                                <th class="text-left px-4 py-3">Issued License</th>
                                <th class="text-left px-4 py-3">Last Provider Message</th>
                                <th class="text-left px-4 py-3">Action</th>
                            </tr>
                        </thead>
                        <tbody>
                        @foreach (var item in Model.Attempts)
                        {
                            <tr class="border-t border-slate-800">
                                <td class="px-4 py-3 font-mono">@item.AttemptId</td>
                                <td class="px-4 py-3 font-mono text-xs">@item.OrderId</td>
                                <td class="px-4 py-3">@item.Amount.ToString("0.00")</td>
                                <td class="px-4 py-3">@item.Currency</td>
                                <td class="px-4 py-3">@item.State</td>
                                <td class="px-4 py-3">@item.CreatedAt.ToString("u")</td>
                                <td class="px-4 py-3">@item.UpdatedAt.ToString("u")</td>
                                <td class="px-4 py-3">
                                    @if (!string.IsNullOrWhiteSpace(item.IssuedLicenseKey))
                                    {
                                        <span class="font-mono text-cyan-300">@item.IssuedLicenseKey</span>
                                    }
                                    else
                                    {
                                        <span class="text-slate-400">pending</span>
                                    }
                                </td>
                                <td class="px-4 py-3">@(item.ProviderMessage ?? "n/a")</td>
                                <td class="px-4 py-3">
                                    <button class="poll-order px-2 py-1 rounded bg-slate-800 hover:bg-slate-700 text-xs" data-order-id="@item.OrderId">Refresh</button>
                                    <div id="order-@item.OrderId" class="mt-1 text-xs text-slate-400"></div>
                                </td>
                            </tr>
                        }
                        </tbody>
                    </table>
                </div>
            }
        </section>
    </section>
</div>
