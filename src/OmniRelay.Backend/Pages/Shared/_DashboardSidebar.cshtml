@{
    var current = (ViewData["DashboardNav"] as string ?? string.Empty).Trim().ToLowerInvariant();
    string LinkClass(string key) =>
        current == key
            ? "block px-3 py-2 rounded-lg bg-cyan-500 text-slate-900 font-semibold"
            : "block px-3 py-2 rounded-lg hover:bg-slate-800 text-slate-200";
}

<aside class="rounded-xl border border-slate-800 bg-slate-900 p-4 h-fit">
    <p class="text-xs uppercase tracking-widest text-slate-400 mb-3">Account</p>
    <nav class="space-y-2 text-sm">
        <a href="/dashboard" class="@LinkClass("dashboard")">Dashboard</a>
        <a href="/dashboard/trial" class="@LinkClass("trial")">Free Trial</a>
        <a href="/dashboard/licenses" class="@LinkClass("licenses")">Licenses</a>
        <a href="/dashboard/billing" class="@LinkClass("billing")">Billing</a>
    </nav>
</aside>
