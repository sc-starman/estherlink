<Page x:Class="EstherLink.UI.Views.Pages.ServiceStatusPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      mc:Ignorable="d"
      Title="Service Status"
      Background="{DynamicResource Brush.Background}">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="28" MaxWidth="980">
            <TextBlock Text="Service Status" Style="{StaticResource SectionTitleTextStyle}"/>
            <TextBlock Text="Manage Windows service lifecycle and inspect live runtime state." Style="{StaticResource MutedTextStyle}" Margin="0,0,0,14"/>

            <WrapPanel Margin="0,0,0,14">
                <Button Content="Refresh Status" Command="{Binding RefreshCommand}" Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,10,0"/>
                <Button Content="Install/Start Service" Command="{Binding InstallStartServiceCommand}" Style="{StaticResource PrimaryButtonStyle}" Margin="0,0,10,0"/>
                <Button Content="Stop Service" Command="{Binding StopServiceCommand}" Style="{StaticResource SecondaryButtonStyle}"/>
            </WrapPanel>

            <Border Style="{StaticResource CardStyle}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="240"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="Windows Service" Style="{StaticResource FormLabelStyle}"/>
                    <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding ServiceState}" Style="{StaticResource ValueTextStyle}"/>

                    <TextBlock Grid.Row="1" Text="Proxy Running" Style="{StaticResource FormLabelStyle}"/>
                    <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding Status.ProxyRunning}" Style="{StaticResource ValueTextStyle}"/>

                    <TextBlock Grid.Row="2" Text="Proxy Listen Port" Style="{StaticResource FormLabelStyle}"/>
                    <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding Status.ProxyListenPort}" Style="{StaticResource ValueTextStyle}"/>

                    <TextBlock Grid.Row="3" Text="License Valid" Style="{StaticResource FormLabelStyle}"/>
                    <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding Status.LicenseValid}" Style="{StaticResource ValueTextStyle}"/>

                    <TextBlock Grid.Row="4" Text="Tunnel Connected" Style="{StaticResource FormLabelStyle}"/>
                    <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding Status.TunnelConnected}" Style="{StaticResource ValueTextStyle}"/>

                    <TextBlock Grid.Row="5" Text="Tunnel Last Connected (UTC)" Style="{StaticResource FormLabelStyle}"/>
                    <TextBlock Grid.Row="5" Grid.Column="1" Text="{Binding Status.TunnelLastConnectedAtUtc}" Style="{StaticResource ValueTextStyle}"/>

                    <TextBlock Grid.Row="6" Text="Tunnel Reconnect Count" Style="{StaticResource FormLabelStyle}"/>
                    <TextBlock Grid.Row="6" Grid.Column="1" Text="{Binding Status.TunnelReconnectCount}" Style="{StaticResource ValueTextStyle}"/>

                    <TextBlock Grid.Row="7" Text="Tunnel Last Error" Style="{StaticResource FormLabelStyle}"/>
                    <TextBlock Grid.Row="7" Grid.Column="1" Text="{Binding Status.TunnelLastError}" TextWrapping="Wrap" Style="{StaticResource ValueTextStyle}"/>

                    <TextBlock Grid.Row="8" Text="Whitelist Count" Style="{StaticResource FormLabelStyle}"/>
                    <TextBlock Grid.Row="8" Grid.Column="1" Text="{Binding Status.WhitelistCount}" Style="{StaticResource ValueTextStyle}"/>

                    <TextBlock Grid.Row="9" Text="Last Error" Style="{StaticResource FormLabelStyle}"/>
                    <TextBlock Grid.Row="9" Grid.Column="1" Text="{Binding Status.LastError}" TextWrapping="Wrap" Style="{StaticResource ValueTextStyle}"/>
                </Grid>
            </Border>

            <TextBlock Text="{Binding Feedback}" Style="{StaticResource FeedbackTextStyle}" Margin="0,12,0,0"/>
        </StackPanel>
    </ScrollViewer>
</Page>