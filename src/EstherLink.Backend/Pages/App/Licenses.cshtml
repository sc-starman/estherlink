@page "/dashboard/licenses"
@model EstherLink.Backend.Pages.App.LicensesModel
@{
    ViewData["Title"] = "Licenses";
    ViewData["DashboardNav"] = "licenses";
}

<div class="max-w-7xl mx-auto px-4 py-10 grid md:grid-cols-[240px_1fr] gap-6">
    <partial name="_DashboardSidebar" view-data="ViewData" />

    <section class="space-y-6">
        <div>
            <h1 class="text-3xl font-bold">Licenses</h1>
            <p class="text-slate-400 mt-1">Each OmniRelay license is bound to one device at a time. Device moves require transfer.</p>
        </div>

        <article class="rounded-xl border border-slate-800 bg-slate-900 p-5 text-sm text-slate-300">
            <p class="font-semibold text-slate-100 mb-1">Single-Device Policy</p>
            <p>
                A license can be active on one device concurrently. If activation is requested from another device,
                you must transfer the license. Each license supports up to <strong>3 transfers per rolling 365 days</strong>.
            </p>
        </article>

        @if (Model.Items.Count == 0)
        {
            <div class="rounded-xl border border-slate-800 bg-slate-900 p-6 text-slate-300">No licenses yet. Start a trial or purchase a license.</div>
        }
        else
        {
            <div class="overflow-x-auto rounded-xl border border-slate-800 bg-slate-900">
                <table class="min-w-full text-sm">
                    <thead class="bg-slate-950/70 text-slate-300">
                        <tr>
                            <th class="text-left px-4 py-3">License Id</th>
                            <th class="text-left px-4 py-3">License Key</th>
                            <th class="text-left px-4 py-3">Device Id</th>
                            <th class="text-left px-4 py-3">Created At</th>
                            <th class="text-left px-4 py-3">Term</th>
                            <th class="text-left px-4 py-3">Status</th>
                            <th class="text-left px-4 py-3">Plan</th>
                            <th class="text-left px-4 py-3">Transfers (365d)</th>
                            <th class="text-left px-4 py-3">Remaining</th>
                            <th class="text-left px-4 py-3">Last Seen</th>
                        </tr>
                    </thead>
                    <tbody>
                    @foreach (var item in Model.Items)
                    {
                        <tr class="border-t border-slate-800">
                            <td class="px-4 py-3 font-mono text-xs">@item.LicenseId</td>
                            <td class="px-4 py-3">
                                <div class="flex items-center gap-2">
                                    <code class="font-mono text-cyan-300">@item.LicenseKey</code>
                                    <button class="copy-license px-2 py-1 rounded bg-slate-800 hover:bg-slate-700 text-xs" data-key="@item.LicenseKey">Copy</button>
                                </div>
                            </td>
                            <td class="px-4 py-3 font-mono">@item.CurrentDeviceId</td>
                            <td class="px-4 py-3">@item.CreatedAt.ToString("u")</td>
                            <td class="px-4 py-3">@item.Term</td>
                            <td class="px-4 py-3">@item.Status</td>
                            <td class="px-4 py-3">@item.Plan</td>
                            <td class="px-4 py-3">@item.TransfersUsedInWindow</td>
                            <td class="px-4 py-3">@item.TransfersRemainingInWindow</td>
                            <td class="px-4 py-3">@(item.LastSeenAt?.ToString("u") ?? "n/a")</td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        }
    </section>
</div>
