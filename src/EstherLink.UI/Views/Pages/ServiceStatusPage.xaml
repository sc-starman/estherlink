<Page x:Class="EstherLink.UI.Views.Pages.ServiceStatusPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      mc:Ignorable="d"
      Title="Service Status"
      Background="{DynamicResource Brush.Background}">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="28" MaxWidth="1080">
            <TextBlock Text="Service Status" Style="{StaticResource SectionTitleTextStyle}"/>
            <TextBlock Text="Manage Relay (Windows) and Gateway (VPS) services, deploy gateway bundle, and run health checks."
                       Style="{StaticResource MutedTextStyle}"
                       Margin="0,0,0,14"/>

            <Border Style="{StaticResource CardStyle}" Margin="0,0,0,14">
                <StackPanel>
                    <TextBlock Text="Combined Operations" FontWeight="SemiBold" Margin="0,0,0,10"/>
                    <WrapPanel Margin="0,0,0,12">
                        <Button Content="Install/Start All"
                                Command="{Binding InstallStartAllCommand}"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Margin="0,0,10,0"/>
                        <Button Content="Refresh Status"
                                Command="{Binding RefreshCommand}"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Margin="0,0,10,0"/>
                        <Button Content="Clear Session Sudo Password"
                                Command="{Binding ClearCachedSudoPasswordCommand}"
                                Style="{StaticResource SecondaryButtonStyle}"/>
                    </WrapPanel>

                    <ProgressBar Height="14"
                                 Minimum="0"
                                 Maximum="100"
                                 Value="{Binding OverallProgressPercent}"
                                 Foreground="{DynamicResource Brush.Primary}"
                                 Background="{DynamicResource Brush.InputBackground}"/>
                    <TextBlock Margin="0,8,0,0"
                               Text="{Binding OverallProgressMessage}"
                               Style="{StaticResource MutedTextStyle}"/>
                </StackPanel>
            </Border>

            <Grid Margin="0,0,0,14">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="14"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <TextBlock Text="Relay Service (Windows)" FontWeight="SemiBold" Margin="0,0,0,10"/>

                        <WrapPanel Margin="0,0,0,12">
                            <Button Content="Install/Start Relay"
                                    Command="{Binding InstallStartServiceCommand}"
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    Margin="0,0,10,0"/>
                            <Button Content="Stop Relay"
                                    Command="{Binding StopServiceCommand}"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Margin="0,0,10,0"/>
                            <Button Content="Uninstall Relay"
                                    Command="{Binding UninstallRelayServiceCommand}"
                                    Style="{StaticResource SecondaryButtonStyle}"/>
                        </WrapPanel>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="170"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Text="Service State" Style="{StaticResource FormLabelStyle}"/>
                            <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding ServiceState}" Style="{StaticResource ValueTextStyle}"/>

                            <TextBlock Grid.Row="1" Text="Proxy Running" Style="{StaticResource FormLabelStyle}"/>
                            <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding Status.ProxyRunning}" Style="{StaticResource ValueTextStyle}"/>

                            <TextBlock Grid.Row="2" Text="Tunnel Connected" Style="{StaticResource FormLabelStyle}"/>
                            <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding Status.TunnelConnected}" Style="{StaticResource ValueTextStyle}"/>

                            <TextBlock Grid.Row="3" Text="Last Error" Style="{StaticResource FormLabelStyle}"/>
                            <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding Status.LastError}" TextWrapping="Wrap" Style="{StaticResource ValueTextStyle}"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <Border Grid.Column="2" Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <TextBlock Text="Gateway Service (VPS)" FontWeight="SemiBold" Margin="0,0,0,10"/>

                        <WrapPanel Margin="0,0,0,12">
                            <Button Content="Install Gateway"
                                    Command="{Binding InstallGatewayCommand}"
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    Margin="0,0,8,0"/>
                            <Button Content="Start"
                                    Command="{Binding StartGatewayCommand}"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Margin="0,0,8,0"/>
                            <Button Content="Stop"
                                    Command="{Binding StopGatewayCommand}"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Margin="0,0,8,0"/>
                            <Button Content="Uninstall"
                                    Command="{Binding UninstallGatewayCommand}"
                                    Style="{StaticResource SecondaryButtonStyle}"/>
                        </WrapPanel>

                        <WrapPanel Margin="0,0,0,12">
                            <Button Content="Gateway Health Check"
                                    Command="{Binding HealthCheckGatewayCommand}"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Margin="0,0,10,0"/>
                            <TextBlock VerticalAlignment="Center"
                                       Text="{Binding GatewayHealthSummary}"
                                       Style="{StaticResource ValueTextStyle}"/>
                        </WrapPanel>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="190"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Text="Gateway State" Style="{StaticResource FormLabelStyle}"/>
                            <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding GatewayServiceState}" TextWrapping="Wrap" Style="{StaticResource ValueTextStyle}"/>

                            <TextBlock Grid.Row="1" Text="Bundle Version" Style="{StaticResource FormLabelStyle}"/>
                            <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding BundleVersion}" Style="{StaticResource ValueTextStyle}"/>

                            <TextBlock Grid.Row="2" Text="Sudo Password Cache" Style="{StaticResource FormLabelStyle}"/>
                            <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding HasCachedSudoPassword}" Style="{StaticResource ValueTextStyle}"/>

                            <TextBlock Grid.Row="3" Text="Backend Listener" Style="{StaticResource FormLabelStyle}"/>
                            <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding GatewayHealthReport.BackendListener}" Style="{StaticResource ValueTextStyle}"/>

                            <TextBlock Grid.Row="4" Text="Ingress Listener" Style="{StaticResource FormLabelStyle}"/>
                            <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding GatewayHealthReport.PublicListener}" Style="{StaticResource ValueTextStyle}"/>

                            <TextBlock Grid.Row="5" Text="Panel Listener" Style="{StaticResource FormLabelStyle}"/>
                            <TextBlock Grid.Row="5" Grid.Column="1" Text="{Binding GatewayHealthReport.PanelListener}" Style="{StaticResource ValueTextStyle}"/>
                        </Grid>
                    </StackPanel>
                </Border>
            </Grid>

            <Border Style="{StaticResource CardStyle}" Margin="0,0,0,8">
                <StackPanel>
                    <TextBlock Text="Operation Log" FontWeight="SemiBold" Margin="0,0,0,10"/>
                    <TextBox Text="{Binding OperationLog}"
                             IsReadOnly="True"
                             Height="200"
                             VerticalScrollBarVisibility="Auto"
                             HorizontalScrollBarVisibility="Auto"
                             TextWrapping="Wrap"
                             Style="{StaticResource MultilineTextBoxStyle}"/>
                </StackPanel>
            </Border>

            <TextBlock Text="{Binding Feedback}" Style="{StaticResource FeedbackTextStyle}" Margin="0,6,0,0"/>
        </StackPanel>
    </ScrollViewer>
</Page>
