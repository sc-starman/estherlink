# Hidden 3x-ui base URL (with base path), example:
# XUI_BASE_URL=http://127.0.0.1:27431/abcxyz
XUI_BASE_URL=

# Managed inbound id from 3x-ui.
XUI_INBOUND_ID=

# Cookie/session encryption secret (>= 32 chars).
SESSION_SECRET=

# Optional override host used when generating VLESS config links.
PANEL_PUBLIC_HOST=

# Optional panel public port shown by runtime.
PANEL_PUBLIC_PORT=443