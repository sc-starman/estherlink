@page "/account/login"
@model EstherLink.Backend.Pages.Account.LoginModel
@{
    ViewData["Title"] = "Login";
}

<div class="max-w-md mx-auto px-4 py-16">
    <h1 class="text-3xl font-bold mb-6">Sign in to OmniRelay</h1>

    @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
    {
        <div class="mb-4 rounded border border-red-500/50 bg-red-500/10 p-3 text-red-200">@Model.ErrorMessage</div>
    }
    @if (!string.IsNullOrWhiteSpace(Model.SuccessMessage))
    {
        <div class="mb-4 rounded border border-green-500/50 bg-green-500/10 p-3 text-green-200">@Model.SuccessMessage</div>
    }

    <form id="loginForm" method="post" class="space-y-4 rounded-xl border border-slate-800 bg-slate-900 p-6">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="ReturnUrl" />
        <input asp-for="Input.RecaptchaToken" type="hidden" id="loginRecaptchaToken" />

        <div>
            <label asp-for="Input.Email" class="block text-sm mb-1">Email</label>
            <input asp-for="Input.Email" class="w-full rounded bg-slate-800 border border-slate-700 px-3 py-2" />
            <span asp-validation-for="Input.Email" class="text-red-300 text-xs"></span>
        </div>
        <div>
            <label asp-for="Input.Password" class="block text-sm mb-1">Password</label>
            <input asp-for="Input.Password" class="w-full rounded bg-slate-800 border border-slate-700 px-3 py-2" />
            <span asp-validation-for="Input.Password" class="text-red-300 text-xs"></span>
        </div>
        <div class="flex items-center gap-2">
            <input asp-for="Input.RememberMe" />
            <label asp-for="Input.RememberMe">Remember me</label>
        </div>

        <button type="submit" class="w-full rounded bg-cyan-500 text-slate-900 font-semibold px-4 py-2 hover:bg-cyan-400">Login</button>
    </form>

    <p class="mt-4 text-sm text-slate-400">Need an account? <a href="/account/register" class="text-cyan-300">Register</a></p>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    @if (Model.RecaptchaEnabled && !string.IsNullOrWhiteSpace(Model.RecaptchaSiteKey))
    {
        <script src="https://www.google.com/recaptcha/api.js?render=@Model.RecaptchaSiteKey"></script>
        <script>
            (function () {
                const form = document.getElementById("loginForm");
                if (!form || !window.grecaptcha) return;

                form.addEventListener("submit", function (event) {
                    if (form.dataset.recaptchaReady === "true") return;
                    event.preventDefault();

                    grecaptcha.ready(function () {
                        grecaptcha.execute("@Model.RecaptchaSiteKey", { action: "login_form" })
                            .then(function (token) {
                                document.getElementById("loginRecaptchaToken").value = token || "";
                                form.dataset.recaptchaReady = "true";
                                form.submit();
                            });
                    });
                });
            })();
        </script>
    }
}
