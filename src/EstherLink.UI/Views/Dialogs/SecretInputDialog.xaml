<Window x:Class="EstherLink.UI.Views.Dialogs.SecretInputDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Set Secret"
        Width="540"
        Height="280"
        MinWidth="520"
        MinHeight="260"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{DynamicResource Brush.Background}">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock x:Name="PromptTitleTextBlock"
                   Grid.Row="0"
                   FontSize="22"
                   FontWeight="SemiBold"
                   Foreground="{DynamicResource Brush.Text}"/>

        <TextBlock x:Name="PromptDescriptionTextBlock"
                   Grid.Row="1"
                   Margin="0,8,0,0"
                   Foreground="{DynamicResource Brush.MutedText}"
                   TextWrapping="Wrap"/>

        <Grid Grid.Row="2" Margin="0,18,0,0">
            <TextBox x:Name="VisibleSecretTextBox"
                     Style="{StaticResource FormTextBoxStyle}"
                     Visibility="Collapsed"
                     TextChanged="VisibleSecretTextBox_OnTextChanged"/>
            <PasswordBox x:Name="HiddenSecretPasswordBox"
                         Style="{StaticResource FormPasswordBoxStyle}"
                         PasswordChanged="HiddenSecretPasswordBox_OnPasswordChanged"/>
        </Grid>

        <CheckBox x:Name="ShowSecretCheckBox"
                  Grid.Row="3"
                  Margin="0,10,0,0"
                  VerticalAlignment="Top"
                  Foreground="{DynamicResource Brush.MutedText}"
                  Content="Show value"
                  Checked="ShowSecretCheckBox_OnChanged"
                  Unchecked="ShowSecretCheckBox_OnChanged"/>

        <StackPanel Grid.Row="4"
                    Margin="0,16,0,0"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <Button Content="Cancel"
                    Width="100"
                    Margin="0,0,10,0"
                    Style="{StaticResource SecondaryButtonStyle}"
                    Click="CancelButton_OnClick"/>
            <Button Content="Save"
                    Width="110"
                    Style="{StaticResource PrimaryButtonStyle}"
                    Click="SaveButton_OnClick"/>
        </StackPanel>
    </Grid>
</Window>
