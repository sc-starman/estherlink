<Page x:Class="EstherLink.UI.Views.Pages.NetworkConfigPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      mc:Ignorable="d"
      Title="Network Configuration"
      Background="{DynamicResource Brush.Background}">
    <Page.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
    </Page.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="28" MaxWidth="980">
            <TextBlock Text="Network Configuration" Style="{StaticResource SectionTitleTextStyle}"/>
            <TextBlock Text="Configure adapter routing, proxy listener, and SSH reverse tunnel parameters." Style="{StaticResource MutedTextStyle}" Margin="0,0,0,16"/>

            <Border Style="{StaticResource CardStyle}" Margin="0,0,0,14">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="220"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="Proxy Listen Port" Style="{StaticResource FormLabelStyle}"/>
                    <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding State.ProxyPortText, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FormTextBoxStyle}"/>

                    <TextBlock Grid.Row="1" Text="VPS Network (IC1)" Style="{StaticResource FormLabelStyle}"/>
                    <ComboBox Grid.Row="1" Grid.Column="1"
                              ItemsSource="{Binding State.Adapters}"
                              SelectedItem="{Binding State.VpsAdapter}"
                              DisplayMemberPath="Display"
                              Style="{StaticResource FormComboBoxStyle}"/>

                    <TextBlock Grid.Row="2" Text="Outgoing Network (IC2)" Style="{StaticResource FormLabelStyle}"/>
                    <ComboBox Grid.Row="2" Grid.Column="1"
                              ItemsSource="{Binding State.Adapters}"
                              SelectedItem="{Binding State.OutgoingAdapter}"
                              DisplayMemberPath="Display"
                              Style="{StaticResource FormComboBoxStyle}"/>
                </Grid>
            </Border>

            <Border Style="{StaticResource CardStyle}" Margin="0,0,0,14">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="220"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="Tunnel Host" Style="{StaticResource FormLabelStyle}"/>
                    <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding State.TunnelHost, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FormTextBoxStyle}"/>

                    <TextBlock Grid.Row="1" Text="Tunnel SSH Port" Style="{StaticResource FormLabelStyle}"/>
                    <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding State.TunnelSshPortText, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FormTextBoxStyle}"/>

                    <TextBlock Grid.Row="2" Text="Tunnel Remote Port" Style="{StaticResource FormLabelStyle}"/>
                    <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding State.TunnelRemotePortText, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FormTextBoxStyle}"/>

                    <TextBlock Grid.Row="3" Text="Tunnel User" Style="{StaticResource FormLabelStyle}"/>
                    <TextBox Grid.Row="3" Grid.Column="1" Text="{Binding State.TunnelUser, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FormTextBoxStyle}"/>

                    <TextBlock Grid.Row="4" Text="Authentication Method" Style="{StaticResource FormLabelStyle}"/>
                    <ComboBox Grid.Row="4" Grid.Column="1"
                              SelectedValue="{Binding State.TunnelAuthMethod}"
                              SelectedValuePath="Tag"
                              Style="{StaticResource FormComboBoxStyle}">
                        <ComboBoxItem Content="Host Key File" Tag="host_key"/>
                        <ComboBoxItem Content="Password" Tag="password"/>
                    </ComboBox>

                    <TextBlock Grid.Row="5"
                               Text="Host Key File"
                               Style="{StaticResource FormLabelStyle}"
                               Visibility="{Binding IsHostKeyAuthSelected, Converter={StaticResource BoolToVisibilityConverter}}"/>
                    <StackPanel Grid.Row="5"
                                Grid.Column="1"
                                Orientation="Horizontal"
                                Visibility="{Binding IsHostKeyAuthSelected, Converter={StaticResource BoolToVisibilityConverter}}">
                        <TextBox Width="520" Text="{Binding State.TunnelKeyPath, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FormTextBoxStyle}"/>
                        <Button Content="Choose File"
                                Margin="10,6,0,6"
                                Command="{Binding BrowseTunnelKeyCommand}"
                                Style="{StaticResource SecondaryButtonStyle}"/>
                    </StackPanel>

                    <TextBlock Grid.Row="6"
                               Text="Key Passphrase"
                               Style="{StaticResource FormLabelStyle}"
                               Visibility="{Binding IsHostKeyAuthSelected, Converter={StaticResource BoolToVisibilityConverter}}"/>
                    <StackPanel Grid.Row="6"
                                Grid.Column="1"
                                Orientation="Horizontal"
                                VerticalAlignment="Center"
                                Visibility="{Binding IsHostKeyAuthSelected, Converter={StaticResource BoolToVisibilityConverter}}">
                        <TextBlock Text="{Binding KeyPassphraseState}" Style="{StaticResource ValueTextStyle}" Width="130"/>
                        <Button Content="Set Passphrase"
                                Command="{Binding SetKeyPassphraseCommand}"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Margin="0,6,0,6"/>
                        <Button Content="Clear"
                                Command="{Binding ClearKeyPassphraseCommand}"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Margin="10,6,0,6"/>
                    </StackPanel>

                    <TextBlock Grid.Row="7"
                               Text="Tunnel Password"
                               Style="{StaticResource FormLabelStyle}"
                               Visibility="{Binding IsPasswordAuthSelected, Converter={StaticResource BoolToVisibilityConverter}}"/>
                    <StackPanel Grid.Row="7"
                                Grid.Column="1"
                                Orientation="Horizontal"
                                VerticalAlignment="Center"
                                Visibility="{Binding IsPasswordAuthSelected, Converter={StaticResource BoolToVisibilityConverter}}">
                        <TextBlock Text="{Binding PasswordState}" Style="{StaticResource ValueTextStyle}" Width="130"/>
                        <Button Content="Set Password"
                                Command="{Binding SetTunnelPasswordCommand}"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Margin="0,6,0,6"/>
                        <Button Content="Clear"
                                Command="{Binding ClearTunnelPasswordCommand}"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Margin="10,6,0,6"/>
                    </StackPanel>

                    <TextBlock Grid.Row="8"
                               Grid.ColumnSpan="2"
                               Margin="0,12,0,4"
                               Text="Gateway Deployment Defaults"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource Brush.Text}"/>

                    <TextBlock Grid.Row="9" Text="Gateway Public Port" Style="{StaticResource FormLabelStyle}"/>
                    <TextBox Grid.Row="9" Grid.Column="1" Text="{Binding State.GatewayPublicPortText, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FormTextBoxStyle}"/>

                    <TextBlock Grid.Row="10" Text="Gateway Panel Port" Style="{StaticResource FormLabelStyle}"/>
                    <TextBox Grid.Row="10" Grid.Column="1" Text="{Binding State.GatewayPanelPortText, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FormTextBoxStyle}"/>

                    <TextBlock Grid.Row="11" Text="Gateway Backend Port" Style="{StaticResource FormLabelStyle}"/>
                    <TextBox Grid.Row="11"
                             Grid.Column="1"
                             Text="{Binding State.GatewayBackendPortText}"
                             IsReadOnly="True"
                             ToolTip="Derived from Tunnel Remote Port."
                             Style="{StaticResource FormTextBoxStyle}"/>
                </Grid>
            </Border>

            <WrapPanel Margin="0,16,0,0">
                <Button Content="Apply Configuration" Command="{Binding ApplyConfigCommand}" Style="{StaticResource PrimaryButtonStyle}"/>
                <Button Content="Test Tunnel Connection"
                        Command="{Binding TestTunnelConnectionCommand}"
                        Margin="10,0,0,0"
                        Style="{StaticResource SecondaryButtonStyle}"/>
            </WrapPanel>
            <TextBlock Text="{Binding Feedback}" Style="{StaticResource FeedbackTextStyle}" Margin="0,10,0,0"/>
        </StackPanel>
    </ScrollViewer>
</Page>
