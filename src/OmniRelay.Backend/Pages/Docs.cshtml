@page "/docs"
@model OmniRelay.Backend.Pages.DocsModel
@{
    ViewData["Title"] = "Documentation";
}

<section class="max-w-7xl mx-auto px-4 py-10 space-y-10">
    <header class="space-y-3">
        <h1 class="text-4xl font-bold">OmniRelay Operator Guide</h1>
        <p class="text-slate-300 max-w-4xl">
            UI-focused documentation for installing, configuring, and operating OmniRelay in production environments.
            This guide intentionally focuses on what users see and do in the interface.
        </p>
        <p class="text-sm text-slate-400">Last updated: @Model.LastUpdated</p>
    </header>

    <nav class="rounded-xl border border-slate-800 bg-slate-900 p-4">
        <p class="text-sm uppercase tracking-wide text-slate-400 mb-3">Sections</p>
        <div class="flex flex-wrap gap-3 text-sm">
            <a class="px-3 py-1 rounded border border-slate-700 hover:border-cyan-400" href="#introduction">1. Introduction</a>
            <a class="px-3 py-1 rounded border border-slate-700 hover:border-cyan-400" href="#requirements">2. System Requirements</a>
            <a class="px-3 py-1 rounded border border-slate-700 hover:border-cyan-400" href="#installation">3. Installation</a>
            <a class="px-3 py-1 rounded border border-slate-700 hover:border-cyan-400" href="#first-launch">4. First Launch</a>
            <a class="px-3 py-1 rounded border border-slate-700 hover:border-cyan-400" href="#activation">5. License Activation</a>
            <a class="px-3 py-1 rounded border border-slate-700 hover:border-cyan-400" href="#relay-config">6. Relay Configuration</a>
            <a class="px-3 py-1 rounded border border-slate-700 hover:border-cyan-400" href="#start-relay">7. Starting a Relay</a>
            <a class="px-3 py-1 rounded border border-slate-700 hover:border-cyan-400" href="#monitoring">8. Monitoring Status</a>
            <a class="px-3 py-1 rounded border border-slate-700 hover:border-cyan-400" href="#troubleshooting">9. Troubleshooting</a>
            <a class="px-3 py-1 rounded border border-slate-700 hover:border-cyan-400" href="#updating">10. Updating</a>
        </div>
    </nav>

    <section id="introduction" class="space-y-4">
        <h2 class="text-3xl font-bold">1. Introduction</h2>
        <div class="space-y-3 text-slate-200">
            @foreach (var line in Model.Introduction)
            {
                <p>@line</p>
            }
        </div>
        <p class="text-sm text-slate-400">Screenshot placeholder: Application home or dashboard overview.</p>
    </section>

    <section id="requirements" class="space-y-4">
        <h2 class="text-3xl font-bold">2. System Requirements</h2>
        <ul class="list-disc pl-6 text-slate-200 space-y-2">
            @foreach (var item in Model.SystemRequirements)
            {
                <li>@item</li>
            }
        </ul>
        <p class="text-sm text-slate-400">Screenshot placeholder: System/network prerequisites checklist.</p>
    </section>

    <section id="installation" class="space-y-4">
        <h2 class="text-3xl font-bold">3. Installation</h2>
        <ol class="list-decimal pl-6 text-slate-200 space-y-2">
            @foreach (var step in Model.InstallationSteps)
            {
                <li>@step</li>
            }
        </ol>
        <p class="text-sm text-slate-400">Screenshot placeholder: Installer wizard screens.</p>
    </section>

    <section id="first-launch" class="space-y-4">
        <h2 class="text-3xl font-bold">4. First Launch</h2>
        <ol class="list-decimal pl-6 text-slate-200 space-y-2">
            @foreach (var step in Model.FirstLaunchSteps)
            {
                <li>@step</li>
            }
        </ol>
        <p class="text-sm text-slate-400">Screenshot placeholder: First-run UI and navigation sidebar.</p>
    </section>

    <section id="activation" class="space-y-4">
        <h2 class="text-3xl font-bold">5. License Activation</h2>
        <ol class="list-decimal pl-6 text-slate-200 space-y-2">
            @foreach (var step in Model.LicenseActivationSteps)
            {
                <li>@step</li>
            }
        </ol>
        <p class="text-sm text-slate-400">Screenshot placeholder: License entry and activation success message.</p>
    </section>

    <section id="relay-config" class="space-y-4">
        <h2 class="text-3xl font-bold">6. Creating a Relay Configuration</h2>
        <p class="text-slate-300">
            Configure relay behavior from <strong>Relay Management</strong>. Use the table below to map each field to its purpose.
        </p>
        <div class="overflow-auto rounded-xl border border-slate-800">
            <table class="min-w-full text-sm">
                <thead class="bg-slate-900 text-slate-300">
                    <tr>
                        <th class="text-left p-3">UI Field</th>
                        <th class="text-left p-3">What You Set</th>
                        <th class="text-left p-3">Valid Values</th>
                        <th class="text-left p-3">Operator Notes</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var row in Model.RelayConfigRows)
                    {
                        <tr class="border-t border-slate-800 bg-slate-950/40 align-top">
                            <td class="p-3 font-semibold">@row.Field</td>
                            <td class="p-3">@row.Description</td>
                            <td class="p-3">@row.ValidValues</td>
                            <td class="p-3">@row.OperatorNotes</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        <p class="text-sm text-slate-400">Screenshot placeholder: Relay Management page with field labels.</p>
    </section>

    <section id="start-relay" class="space-y-4">
        <h2 class="text-3xl font-bold">7. Starting a Relay</h2>
        <ol class="list-decimal pl-6 text-slate-200 space-y-2">
            @foreach (var step in Model.StartingRelaySteps)
            {
                <li>@step</li>
            }
        </ol>
        <p class="text-sm text-slate-400">Screenshot placeholder: Install/Start button flow and successful state.</p>
    </section>

    <section id="monitoring" class="space-y-4">
        <h2 class="text-3xl font-bold">8. Monitoring Status</h2>
        <p class="text-slate-300">
            Use the status panels in Relay Management and Gateway Management to confirm operational readiness.
        </p>
        <div class="overflow-auto rounded-xl border border-slate-800">
            <table class="min-w-full text-sm">
                <thead class="bg-slate-900 text-slate-300">
                    <tr>
                        <th class="text-left p-3">Indicator</th>
                        <th class="text-left p-3">Meaning</th>
                        <th class="text-left p-3">Expected Value</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var row in Model.MonitoringRows)
                    {
                        <tr class="border-t border-slate-800 bg-slate-950/40 align-top">
                            <td class="p-3 font-semibold">@row.Indicator</td>
                            <td class="p-3">@row.Meaning</td>
                            <td class="p-3">@row.ExpectedValue</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        <p class="text-sm text-slate-400">Screenshot placeholder: Health/status cards and operation log panel.</p>
    </section>

    <section id="troubleshooting" class="space-y-4">
        <h2 class="text-3xl font-bold">9. Troubleshooting</h2>
        <div class="overflow-auto rounded-xl border border-slate-800">
            <table class="min-w-full text-sm">
                <thead class="bg-slate-900 text-slate-300">
                    <tr>
                        <th class="text-left p-3">Problem</th>
                        <th class="text-left p-3">What to Do</th>
                        <th class="text-left p-3">How to Confirm Fix</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var row in Model.TroubleshootingRows)
                    {
                        <tr class="border-t border-slate-800 bg-slate-950/40 align-top">
                            <td class="p-3 font-semibold">@row.Problem</td>
                            <td class="p-3">@row.Action</td>
                            <td class="p-3">@row.SuccessCheck</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        <p class="text-sm text-slate-400">Screenshot placeholder: Example warning/error states in UI.</p>
    </section>

    <section id="updating" class="space-y-4">
        <h2 class="text-3xl font-bold">10. Updating the Application</h2>
        <ol class="list-decimal pl-6 text-slate-200 space-y-2">
            @foreach (var step in Model.UpdateSteps)
            {
                <li>@step</li>
            }
        </ol>
        <p class="text-sm text-slate-400">Screenshot placeholder: Download page and post-update validation view.</p>
    </section>
</section>
